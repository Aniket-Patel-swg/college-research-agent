# Required ---------------------------------------------------------------
# Gemini API key. Generate one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional ---------------------------------------------------------------
# HTTP port for the Express server (default 4810).
PORT=4810

# Gemini model. Anything 2.0+ supports the `googleSearch` grounding tool.
# Flash is ~10x cheaper than Pro for our use-case; Pro is more accurate.
#   gemini-2.5-flash       (recommended default)
#   gemini-2.5-pro
#   gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash-lite
# Pass-2 (format-only) model. Defaults to GEMINI_MODEL. Setting it to a
# different model splits free-tier quota between the two passes.
GEMINI_FORMATTER_MODEL=gemini-3.5-flash

# Cache (DynamoDB) -------------------------------------------------------
# We ONLY write to the cache when the agent produced a "complete" record
# (location, establishedYear, websiteUrl, several quickStats, recruiters,
# at least one cutoff trend, and at least one source). Partial results are
# still returned to the caller but they don't pollute the cache.
CACHE_ENABLED=true
CACHE_TABLE_NAME=CollegeResearchCache
CACHE_TTL_SECONDS=604800

AWS_REGION=ap-south-1
# AWS credentials are picked up from the default chain (env vars,
# ~/.aws/credentials, or the EC2/ECS/Lambda role).

# CORS -------------------------------------------------------------------
# Comma-separated list of allowed origins for the frontend.
ALLOWED_ORIGINS=http://localhost:3000
